# Tabylga — environment variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Never commit .env — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# Supabase — get these from https://supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini — https://aistudio.google.com → Get API key
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here

# Groq (fallback LLM) — https://console.groq.com → API Keys
EXPO_PUBLIC_GROQ_API_KEY=your-groq-key-here

# Stripe (test mode) — https://dashboard.stripe.com → Developers → API keys
# Use the pk_test_... publishable key only — never the secret key in the app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
