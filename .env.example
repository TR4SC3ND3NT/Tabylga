# Tabylga — environment variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in your values — never commit .env.local
# ─────────────────────────────────────────────────────────────

# Google Gemini — keep this server-side. Do not expose it in the web bundle.
GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_PROXY_URL=

# Google Maps — https://console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# 2GIS — https://dev.2gis.com
EXPO_PUBLIC_2GIS_API_KEY=

# Unsplash — https://unsplash.com/developers → Your app
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=

# Free public APIs — no key needed, but override for self-hosted instances
EXPO_PUBLIC_OVERPASS_URL=https://overpass-api.de/api/interpreter
EXPO_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org
EXPO_PUBLIC_WIKIPEDIA_URL=https://en.wikipedia.org/api/rest_v1
