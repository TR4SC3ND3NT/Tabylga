# ─── Dependencies ────────────────────────────────────────────
# package-lock.json MUST be committed — new devs run `npm ci`, not `npm install`
node_modules/
.npm/

# ─── Expo & Metro Bundler ────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*
# Папки кэша, которые могут создаваться на Mac
.eslintcache
.stylelintcache

# ─── EAS / native builds ─────────────────────────────────────
.eas/
.kotlin/
/ios
/android
*.ipa
*.apk
*.aab

# ─── Signing & certificates ──────────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ─── Environment & secrets ───────────────────────────────────
# Copy .env.example → .env.local and fill in your keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo

# ─── OS-Specific (Критично для Mac-юзеров!) ──────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ─── Editor & IDE ────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
